# Alert data source: "oref" | "demo"
ALERT_SOURCE=demo

# Pikud HaOref API (requires Israeli IP)
OREF_API_URL=https://www.oref.org.il/WarningMessages/alert/alerts.json

# Polling interval in milliseconds
POLL_INTERVAL_MS=2000

# Vercel KV (optional, uses in-memory store if not set)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Postgres (optional, for historical persistence)
POSTGRES_URL=
